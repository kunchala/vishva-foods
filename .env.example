# =============================================================
# VISHVA FOODS — Environment variables
# Copy to ".env" and fill in. Anything left blank degrades
# gracefully: the site still runs, but that feature is off.
#   - No Stripe keys        → checkout shows "not configured"
#   - No Supabase keys      → menu uses seed data, orders can't persist
#   - DELIVERY_PROVIDER=mock → flat $4.99 quote, no real courier
#   - No Resend key         → confirmation emails are skipped
# =============================================================

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Supabase ----
# Project URL + keys from Supabase dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# These two (VITE_ prefixed) are exposed to the browser — anon key only!
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Stripe ----
# Dashboard → Developers → API keys. Use test keys (sk_test_/pk_test_) first.
STRIPE_SECRET_KEY=sk_test_51Tko5rK56UljiJMc1r4gbbphc1yzjGAeENhOLxSxg5xnMoiq0KsVDov1Nj6irCYKJUAPy0GRybNAgQZon7nL5Ax200UDGFeoWP
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51Tko5rK56UljiJMcsIc8SBeE0netrkyf8nvYZaLu5zZx7pxeGv2QxVIkCXSQl7sdrl91TsmHxdaEBvOXhIcxa41e00FoOfGr77
# From `stripe listen` (dev) or the webhook endpoint settings (prod).
STRIPE_WEBHOOK_SECRET=

# ---- Delivery provider ----
# doordash | uber | mock
DELIVERY_PROVIDER=mock

# DoorDash Drive (https://developer.doordash.com) — from the portal Access Key.
DOORDASH_DEVELOPER_ID=
DOORDASH_KEY_ID=
DOORDASH_SIGNING_SECRET=

# Uber Direct (https://developer.uber.com/docs/deliveries) — from the Direct dashboard.
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
UBER_DIRECT_CUSTOMER_ID=

# ---- Pickup / kitchen address (used as the courier pickup point) ----
RESTAURANT_NAME=Vishva Foods
RESTAURANT_PICKUP_ADDRESS=123 Example St
RESTAURANT_CITY=Ashburn
RESTAURANT_STATE=VA
RESTAURANT_ZIP=20147
RESTAURANT_PHONE=+17035550000
RESTAURANT_PICKUP_INSTRUCTIONS=Ring doorbell on arrival

# ---- Email (Resend: https://resend.com) ----
RESEND_API_KEY=
EMAIL_FROM=Vishva Foods <orders@vishvaindianfoods.com>

# ---- Admin ----
# Any long random string; required to open /admin and update orders.
ADMIN_TOKEN=
